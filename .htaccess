<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /sinaq/
    RewriteRule ^index\.html$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /sinaq/index.html [L]
  </IfModule>
  
  # Permitir CORS y Headers necesarios
  <IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET,POST,OPTIONS,DELETE,PUT"
    Header set Access-Control-Allow-Headers "DNT,X-CustomHeader,Keep-Alive,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Authorization"
    Header set Content-Security-Policy "default-src 'self' data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com; script-src-elem 'self' https://www.googletagmanager.com https://www.google-analytics.com; connect-src 'self' https://*.supabase.co https://login.microsoftonline.com https://*.microsoft.com https://graph.microsoft.com https://api.factorialhr.com https://tecvasa.sharepoint.com https://www.google-analytics.com; media-src 'self' blob: data: https://tecvasa.sharepoint.com; img-src 'self' data: blob: https:; font-src 'self' data:; frame-src 'self' https://login.microsoftonline.com https://*.microsoft.com;"
  </IfModule>